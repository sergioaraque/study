# Build stage
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

# Vite bakes env vars at build time — declare them as build args
# so Coolify (or any CI) can pass them via --build-arg
ARG VITE_APPWRITE_ENDPOINT
ARG VITE_APPWRITE_PROJECT_ID
ARG VITE_APPWRITE_DATABASE_ID
ARG VITE_COL_SEMESTERS
ARG VITE_COL_SUBJECTS
ARG VITE_COL_TOPICS
ARG VITE_COL_STUDY_SESSIONS
ARG VITE_COL_PECS
ARG VITE_COL_EXAMS
ARG VITE_COL_TUTORING_SESSIONS
ARG VITE_COL_TOPIC_TASKS
ARG VITE_BACKEND_URL

ENV VITE_APPWRITE_ENDPOINT=$VITE_APPWRITE_ENDPOINT
ENV VITE_APPWRITE_PROJECT_ID=$VITE_APPWRITE_PROJECT_ID
ENV VITE_APPWRITE_DATABASE_ID=$VITE_APPWRITE_DATABASE_ID
ENV VITE_COL_SEMESTERS=$VITE_COL_SEMESTERS
ENV VITE_COL_SUBJECTS=$VITE_COL_SUBJECTS
ENV VITE_COL_TOPICS=$VITE_COL_TOPICS
ENV VITE_COL_STUDY_SESSIONS=$VITE_COL_STUDY_SESSIONS
ENV VITE_COL_PECS=$VITE_COL_PECS
ENV VITE_COL_EXAMS=$VITE_COL_EXAMS
ENV VITE_COL_TUTORING_SESSIONS=$VITE_COL_TUTORING_SESSIONS
ENV VITE_COL_TOPIC_TASKS=$VITE_COL_TOPIC_TASKS
ENV VITE_BACKEND_URL=$VITE_BACKEND_URL

RUN npm run build

# Serve stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
